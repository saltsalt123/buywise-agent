# BuyWise Agent - Environment Variables
# Copy this to .env and fill in your values

# === LLM Provider ===
OPENAI_API_KEY=
# Alternative: use any OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# === Database ===
DATABASE_URL=postgresql+asyncpg://buywise:buywise@db:5432/buywise
DATABASE_URL_SYNC=postgresql://buywise:buywise@db:5432/buywise

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === App ===
APP_SECRET_KEY=change-me-to-a-random-secret
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50

# === Eval ===
# Set to "true" to use fake LLM responses for cheap CI eval runs
FAKE_LLM_MODE=false
SMALL_EVAL_MODE=false
